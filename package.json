{
  "name": "guseyn.com",
  "version": "2.0.82",
  "description": "My blog.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "lint": "npx eslint",
    "start": "node web-app/main.js",
    "restart": "node web-app/restart.js",
    "start:local": "ENV=local npm run start",
    "start:prod": "ENV=prod npm run start",
    "restart:local": "ENV=local npm run restart",
    "restart:prod": "ENV=prod npm run restart",
    "start:docker:local": "docker-compose -f docker-compose.yml up --build --force-recreate --remove-orphans",
    "start:docker:prod": "DOMAIN=guseyn.com,www.guseyn.com DOMAIN_EMAIL=guseyn@guseyn.com CERTBOT_MODE=generate docker-compose -f docker-compose.prod.yml up --build --force-recreate --remove-orphans",
    "restart:docker:local": "docker exec -it guseyn.com npm run local:restart",
    "restart:docker:prod": "docker exec -it guseyn.com npm run prod:restart",
    "pull": "node web-app/pull.js",
    "ehtml:update": "rsync -a --delete ../../my-projects/EHTML/src/ web-app/static/js/ehtml",
    "nodes:update": "rsync -a --delete ../../my-projects/nodes.js/nodes/ nodes/",
    "eui:update": "rsync -a --delete ../../my-projects/e-ui/static/js/e-ui/ web-app/static/js/e-ui/ && cp -rf ../../my-projects/e-ui/static/css/e-ui.css web-app/static/css/e-ui.css"
  },
  "author": "guseyn",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "imports": {
    "#nodes/*": "./nodes/*"
  },
  "dependencies": {

  },
  "devDependencies": {
    "eslint": "^8.30.0",
    "eslint-plugin-node": "^11.1.0",
    "glob": "^10.3.10"
  }
}
